# Copy to .env and fill in your keys. Never commit .env.

# Google Gemini — free tier, vision-capable
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Groq — free tier, 6,000 TPM per key
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: second Groq account key for 2× effective TPM (strongly recommended)
# Create a second account at console.groq.com to get an independent TPM bucket
GROQ_API_KEY_2=gsk_...
